# ===================================================================
# AgentDream 梦系统插件配置（VCPtoolbox-Junior 版）
# -------------------------------------------------------------------
# [Junior 协议] 梦插件专属配置（DREAM_*）统一维护在本文件中，
#   不要复制到根 config.env（保持根配置清爽）。
#
# 启用步骤：
#   1) 把本文件（config.env.example）复制为同目录下的 config.env
#   2) 按需调整下面的参数
#   3) 把 plugin-manifest.json.block 改名去掉 .block 以启用插件
#   4) 重启 VCP 服务
#
# [基础依赖] 以下全局配置由根 config.env 注入，插件会自动读取，
#   无需在本文件重复配置：
#     · 向量 / 嵌入模型相关（由 KnowledgeBaseManager 管理）
#     · VCP API 端口 / Key（由 PluginManager 注入到 initialize config）
#     · PROJECT_BASE_PATH（插件自动继承）
#
# [日记路径] Junior 将 agent 日记组织为 Agent/<agentName>/diary/，
#   公共知识库在 knowledge/。插件已适配此结构，无需额外配置。
#
# [进阶覆盖] 通常不需要：
#   AGENT_DIARY_ROOT_PATH=/path/to/Agent          # 覆盖 agent 根
#   KNOWLEDGEBASE_ROOT_PATH=/path/to/knowledge    # 覆盖公共知识库根
# ===================================================================

# 做梦频率 (小时)，默认8小时一次
DREAM_FREQUENCY_HOURS=3

# 做梦时间段开始 (24h制，默认凌晨1点)
DREAM_TIME_WINDOW_START=1

# 做梦时间段结束 (24h制，默认早上6点)
DREAM_TIME_WINDOW_END=8

# 做梦概率 (0-1)，每次到点时掷骰子
DREAM_PROBABILITY=0.6

# --- 联想配置 ---

# 现在已有涟漪算法动态控制联想

# TagMemo 增强因子
DREAM_TAG_BOOST=0.25

# 梦上下文有效时间(小时)
DREAM_CONTEXT_TTL_HOURS=4
# --- 做梦 Agent 列表 (逗号分隔的中文名) ---
DREAM_AGENT_LIST=Nova

# --- Agent 独立配置 ---
# 每个做梦 Agent 的模型和提示词可独立配置。
# 格式与 AgentAssistant 类似，区别在于前缀为 DREAM_AGENT_。
# SYSTEM_PROMPT 暂时留空，由用户后续填充。
#
# 支持占位符: {{MaidName}}, {{Date}}, {{Time}}, {{Today}}

# Agent: Nova
DREAM_AGENT_NOVA_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_NOVA_CHINESE_NAME=Nova
DREAM_AGENT_NOVA_SYSTEM_PROMPT={{agent:DreamNova}}
DREAM_AGENT_NOVA_MAX_OUTPUT_TOKENS=40000
DREAM_AGENT_NOVA_TEMPERATURE=0.85

# Agent: 小克
DREAM_AGENT_XIAOKE_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_XIAOKE_CHINESE_NAME=小克
DREAM_AGENT_XIAOKE_SYSTEM_PROMPT=
DREAM_AGENT_XIAOKE_MAX_OUTPUT_TOKENS=40000
DREAM_AGENT_XIAOKE_TEMPERATURE=0.85

# Agent: 小娜
DREAM_AGENT_XIAONA_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_XIAONA_CHINESE_NAME=小娜
DREAM_AGENT_XIAONA_SYSTEM_PROMPT=
DREAM_AGENT_XIAONA_MAX_OUTPUT_TOKENS=40000
DREAM_AGENT_XIAONA_TEMPERATURE=0.85

# Agent: 小吉
DREAM_AGENT_XIAOJI_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_XIAOJI_CHINESE_NAME=小吉
DREAM_AGENT_XIAOJI_SYSTEM_PROMPT=
DREAM_AGENT_XIAOJI_MAX_OUTPUT_TOKENS=40000
DREAM_AGENT_XIAOJI_TEMPERATURE=0.85

# Agent: 小冰
DREAM_AGENT_XIAOBING_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_XIAOBING_CHINESE_NAME=小冰
DREAM_AGENT_XIAOBING_SYSTEM_PROMPT=
DREAM_AGENT_XIAOBING_MAX_OUTPUT_TOKENS=40000
DREAM_AGENT_XIAOBING_TEMPERATURE=0.85

# Agent: 小雨
DREAM_AGENT_XIAOYU_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_XIAOYU_CHINESE_NAME=小雨
DREAM_AGENT_XIAOYU_SYSTEM_PROMPT=
DREAM_AGENT_XIAOYU_MAX_OUTPUT_TOKENS=40000
