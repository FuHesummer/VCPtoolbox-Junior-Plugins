# Agent: 小绝
DREAM_AGENT_XIAOJUE_MODEL_ID=gemini-2.5-flash-preview-05-20
DREAM_AGENT_XIAOJUE_CHINESE_NAME=小绝
DREAM_AGENT_XIAOJUE_SYSTEM_PROMPT=
DREAM_AGENT_XIAOJUE_MAX_OUTPUT_TOKENS=40000
